# Mapbox — token público (começa com pk_)
VITE_MAPBOX_PUBLIC_TOKEN=pk_your_mapbox_token_here

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Stripe (chaves públicas do frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
VITE_STRIPE_PRO_PRICE_ID=price_...
VITE_STRIPE_ENTERPRISE_PRICE_ID=price_...

# Optional: Notification Services
# VITE_TWILIO_PHONE=+1234567890
# VITE_SENDGRID_API_KEY=SG.xxxxxxxxxxxxx
